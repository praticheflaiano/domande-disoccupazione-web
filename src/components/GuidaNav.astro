---
export interface Props {
    current?: string;
}

const { current } = Astro.props;

const sections = [
    { slug: 'presentare-domanda', label: 'Presentare la domanda', icon: '📝', hint: 'Portale INPS passo-passo, scadenza 68 giorni, mandato' },
    { slug: 'did', label: 'DID Online', icon: '✅', hint: 'Dichiarazione di Immediata Disponibilità al lavoro' },
    { slug: 'dimissioni-giusta-causa', label: 'Dimissioni giusta causa', icon: '🚪', hint: 'Le 7 causali riconosciute e la procedura telematica' },
    { slug: 'dimissioni-trasferimento', label: 'Dimissioni per trasferimento', icon: '📍', hint: 'Cass. 10559/2026: la distanza non basta, serve inadempimento' },
    { slug: 'dimissioni-maternita', label: 'Dimissioni primo anno figlio', icon: '🍼', hint: 'Art. 55 D.Lgs. 151/2001 + convalida ITL' },
    { slug: 'dimissioni-stipendio-non-pagato', label: 'Stipendi non pagati', icon: '💸', hint: 'Soglia 3 mesi + diffida + Fondo di Garanzia INPS' },
    { slug: 'dimissioni-mobbing', label: 'Mobbing e demansionamento', icon: '🛡️', hint: 'Mobbing, straining, demansionamento ex Cass. 811/2021' },
    { slug: 'dimissioni-cessione-azienda', label: 'Cessione d\'azienda', icon: '🏢', hint: 'Art. 2112 c.c., finestra 3 mesi post-trasferimento' },
    { slug: 'pagamenti-accredito', label: 'Quando arriva la NASpI', icon: '💰', hint: 'Calendario pagamenti 2026 + come verificare' },
    { slug: 'sospensione-naspi', label: 'NASpI sospesa: riattivazione', icon: '⏸️', hint: '5 cause principali e procedura di riattivazione' },
    { slug: 'nuovo-lavoro-durante-naspi', label: 'Nuovo lavoro durante NASpI', icon: '🔁', hint: 'Cumulo, sospensione, decadenza per contratti/P.IVA/PrestO' },
    { slug: 'fiscalita', label: 'Fiscalità e CU', icon: '📊', hint: 'NASpI in 730/Redditi, Certificazione Unica, conguaglio' },
    { slug: 'anf', label: 'Assegno Nucleo Familiare', icon: '👨‍👩‍👧', hint: 'Tabelle 2026 e compatibilità con NASpI' },
    { slug: 'maternita-malattia', label: 'Maternità e malattia (durante NASpI)', icon: '🤱', hint: 'Sospensione, indennità sostitutiva, congedi' },
    { slug: 'estero-u2', label: 'NASpI all\'estero', icon: '🇪🇺', hint: 'Portabilità UE, modulo U2, proroga 3 mesi' },
    { slug: 'ricorso', label: 'Domanda rigettata', icon: '⚖️', hint: 'Ricorso amministrativo INPS e giudiziario' },
    { slug: 'precari-scuola', label: 'NASpI per precari scuola', icon: '🏫', hint: 'Docenti ATA precari: scadenza 30/06 o 31/08, SIISL, rientro a settembre' },
    { slug: 'naspi-stagionali', label: 'NASpI stagionali', icon: '🏖️', hint: 'Turismo, balneari, agricoltura: cumulo settimane e formazione tra stagioni' },
    { slug: 'sfl-naspi', label: 'SFL vs NASpI', icon: '🎓', hint: 'Supporto Formazione Lavoro 500 €/mese: per chi non ha NASpI' },
    { slug: 'adi-naspi', label: 'ADI e NASpI', icon: '🏠', hint: 'Assegno di Inclusione: cumulabilità, impatto ISEE, transizione' },
    { slug: 'naspi-gig-economy', label: 'Rider, autisti, freelancer', icon: '🛵', hint: 'Gig economy: NASpI, DIS-COLL, ISCRO, chiusura P.IVA' },
    { slug: 'naspi-apprendistato', label: 'NASpI dopo apprendistato', icon: '🔧', hint: 'Mancata conferma, licenziamento, tipologie duale/professionalizzante' },
];
---

<nav aria-label="Sezioni della guida operativa" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {sections.map((section) => {
        const isCurrent = current === section.slug;
        const classes = [
            'block rounded-2xl border p-4 transition-all',
            isCurrent
                ? 'bg-teal-50 border-teal-300 ring-2 ring-teal-200 cursor-default'
                : 'bg-white border-slate-200 hover:border-teal-300 hover:shadow-md',
        ].join(' ');
        return (
            <a
                href={isCurrent ? undefined : `/guida/${section.slug}`}
                aria-current={isCurrent ? 'page' : undefined}
                class={classes}
            >
                <div class="flex items-start gap-3">
                    <span class="text-2xl" aria-hidden="true">{section.icon}</span>
                    <div>
                        <div class={`font-bold ${isCurrent ? 'text-teal-900' : 'text-slate-900'}`}>{section.label}</div>
                        <p class="text-xs text-slate-500 mt-1 leading-relaxed">{section.hint}</p>
                    </div>
                </div>
            </a>
        );
    })}
</nav>
