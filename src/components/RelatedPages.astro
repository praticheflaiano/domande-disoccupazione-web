---
import { relatedFor } from '../lib/related';

export interface Props {
    current: string;
    title?: string;
}

const { current, title = 'Approfondisci' } = Astro.props;
const links = relatedFor(current);
---

{links.length > 0 && (
    <aside aria-label="Pagine correlate" class="max-w-4xl mx-auto px-4 py-10 border-t border-slate-200">
        <h2 class="text-xl md:text-2xl font-bold text-slate-900 mb-6">{title}</h2>
        <div class="grid md:grid-cols-3 gap-4">
            {links.map((link) => (
                <a
                    href={link.href}
                    class="group block bg-white hover:bg-slate-50 border border-slate-200 hover:border-blue-300 rounded-xl p-5 shadow-sm hover:shadow-md transition-all"
                >
                    <div class="flex items-start justify-between gap-2 mb-2">
                        <h3 class="font-bold text-slate-900 group-hover:text-blue-700 leading-tight">{link.label}</h3>
                        <span class="text-blue-600 group-hover:translate-x-1 transition-transform" aria-hidden="true">→</span>
                    </div>
                    <p class="text-sm text-slate-600 leading-relaxed">{link.description}</p>
                </a>
            ))}
        </div>
    </aside>
)}
