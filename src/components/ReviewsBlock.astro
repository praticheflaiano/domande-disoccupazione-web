---
import { GOOGLE_STATS, reviews } from '../data/reviews';
import { GOOGLE_BUSINESS_URL, SITE_URL } from '../lib/routes';

const hasReviews = reviews.length > 0 && GOOGLE_STATS !== null;
const businessLink = GOOGLE_STATS?.profileUrl || GOOGLE_BUSINESS_URL;

const formatDate = (iso: string) =>
    new Intl.DateTimeFormat('it-IT', { month: 'short', year: 'numeric' }).format(new Date(iso));

// Se e solo se le recensioni sono reali, emettiamo AggregateRating + Review schema.
const reviewSchema = hasReviews && GOOGLE_STATS
    ? {
          '@context': 'https://schema.org',
          '@type': 'LocalBusiness',
          '@id': `${SITE_URL}/#organization`,
          aggregateRating: {
              '@type': 'AggregateRating',
              ratingValue: GOOGLE_STATS.average.toFixed(1),
              reviewCount: GOOGLE_STATS.count,
              bestRating: '5',
              worstRating: '1',
          },
          review: reviews.slice(0, 5).map((r) => ({
              '@type': 'Review',
              author: { '@type': 'Person', name: r.author },
              datePublished: r.date,
              reviewRating: {
                  '@type': 'Rating',
                  ratingValue: r.rating,
                  bestRating: '5',
                  worstRating: '1',
              },
              reviewBody: r.text,
          })),
      }
    : null;
---

{reviewSchema && <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />}

<section aria-label="Recensioni Google" class="max-w-6xl mx-auto px-4 py-10">
    {hasReviews && GOOGLE_STATS ? (
        <>
            <header class="flex flex-wrap items-end justify-between gap-4 mb-8">
                <div>
                    <div class="flex items-center gap-2 mb-1">
                        <span class="text-3xl font-extrabold text-slate-900">{GOOGLE_STATS.average.toFixed(1)}</span>
                        <span class="flex items-center" aria-label={`${GOOGLE_STATS.average.toFixed(1)} su 5`}>
                            {Array.from({ length: 5 }).map(() => (
                                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.96a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.446a1 1 0 00-.364 1.118l1.286 3.96c.3.921-.755 1.688-1.54 1.118l-3.368-2.446a1 1 0 00-1.176 0l-3.368 2.446c-.784.57-1.838-.197-1.54-1.118l1.286-3.96a1 1 0 00-.364-1.118L2.05 9.387c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.96z" />
                                </svg>
                            ))}
                        </span>
                        <span class="text-slate-500 text-sm">su {GOOGLE_STATS.count} recensioni Google</span>
                    </div>
                    <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Cosa dicono i nostri clienti</h2>
                </div>
                <a href={businessLink} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-blue-600 hover:text-blue-700">
                    Leggi tutte le recensioni su Google →
                </a>
            </header>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
                {reviews.slice(0, 6).map((r) => (
                    <article class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm">
                        <header class="flex items-center justify-between mb-3">
                            <span class="flex items-center" aria-label={`${r.rating} stelle`}>
                                {Array.from({ length: r.rating }).map(() => (
                                    <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.96a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.446a1 1 0 00-.364 1.118l1.286 3.96c.3.921-.755 1.688-1.54 1.118l-3.368-2.446a1 1 0 00-1.176 0l-3.368 2.446c-.784.57-1.838-.197-1.54-1.118l1.286-3.96a1 1 0 00-.364-1.118L2.05 9.387c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69l1.286-3.96z" />
                                    </svg>
                                ))}
                            </span>
                            <time datetime={r.date} class="text-xs text-slate-400">{formatDate(r.date)}</time>
                        </header>
                        <p class="text-slate-700 leading-relaxed text-sm mb-3">{r.text}</p>
                        <footer class="text-sm font-semibold text-slate-900">— {r.author}</footer>
                    </article>
                ))}
            </div>
        </>
    ) : (
        <div class="bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm">
            <div class="flex flex-col md:flex-row items-start md:items-center gap-6 justify-between">
                <div>
                    <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-2">Recensioni verificate su Google</h2>
                    <p class="text-slate-600 leading-relaxed max-w-xl">
                        I nostri clienti ci recensiscono direttamente sul nostro profilo Google Business. Leggi le testimonianze
                        reali o lascia la tua dopo aver utilizzato il nostro servizio.
                    </p>
                </div>
                <a
                    href={businessLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 bg-white border-2 border-slate-900 hover:bg-slate-900 hover:text-white text-slate-900 font-bold px-6 py-3 rounded-xl transition-colors flex-shrink-0"
                >
                    <svg class="w-5 h-5" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                        <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.83z" />
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38z" />
                    </svg>
                    Apri il profilo Google
                </a>
            </div>
        </div>
    )}
</section>
