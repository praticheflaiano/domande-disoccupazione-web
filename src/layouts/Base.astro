---
import '../index.css';
import { SITE_URL } from '../lib/routes';
import SiteHeader from '../components/SiteHeader.astro';
import Footer from '../components/Footer';
import StickyContactBar from '../components/StickyContactBar';
import AccessibilityToolbar from '../components/AccessibilityToolbar';
import CookieBanner from '../components/CookieBanner';
import ExitIntentModal from '../components/ExitIntentModal';
import { LAST_UPDATED } from '../constants';

export interface Props {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    ogType?: 'website' | 'article';
    publishedTime?: string;
    modifiedTime?: string;
    articleSection?: string;
    articleAuthor?: string;
    breadcrumbs?: Array<{ label: string; href: string }>;
    jsonLd?: unknown;
}

const {
    title,
    description,
    canonical,
    ogImage = '/og/cover.png',
    ogType = 'website',
    publishedTime,
    modifiedTime,
    articleSection,
    articleAuthor,
    breadcrumbs,
    jsonLd,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = canonical ?? new URL(currentPath, SITE_URL).toString();
const fullOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).toString();

const organizationSchema = {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${SITE_URL}/#organization`,
    name: 'Centro Pratiche Flaiano',
    url: SITE_URL,
    telephone: '+390697845429',
    email: 'info@praticheflaiano.it',
    address: {
        '@type': 'PostalAddress',
        streetAddress: 'Via Filoteo Alberini, 25/int 10',
        addressLocality: 'Roma',
        postalCode: '00139',
        addressRegion: 'RM',
        addressCountry: 'IT',
    },
    openingHoursSpecification: [
        {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'],
            opens: '09:30',
            closes: '18:00',
        },
        {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: 'Friday',
            opens: '09:30',
            closes: '14:00',
        },
    ],
    areaServed: 'IT',
    priceRange: '€€',
    description:
        "Centro Pratiche Flaiano (Roma) assiste nella domanda NASpI e disoccupazione INPS, con calcolatore online, guide aggiornate e invio domanda telematica.",
};

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0
    ? {
          '@context': 'https://schema.org',
          '@type': 'BreadcrumbList',
          itemListElement: breadcrumbs.map((b, i) => ({
              '@type': 'ListItem',
              position: i + 1,
              name: b.label,
              item: new URL(b.href, SITE_URL).toString(),
          })),
      }
    : null;

// Google Analytics 4 measurement ID (set in Vercel env: PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXX)
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
---

<!DOCTYPE html>
<html lang="it">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="alternate" hreflang="it-IT" href={canonicalUrl} />

        <meta property="og:type" content={ogType} />
        <meta property="og:locale" content="it_IT" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={fullOgImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="Centro Pratiche Flaiano" />
        {ogType === 'article' && publishedTime && (
            <meta property="article:published_time" content={publishedTime} />
        )}
        {ogType === 'article' && modifiedTime && (
            <meta property="article:modified_time" content={modifiedTime} />
        )}
        {ogType === 'article' && articleSection && (
            <meta property="article:section" content={articleSection} />
        )}
        {ogType === 'article' && articleAuthor && (
            <meta property="article:author" content={articleAuthor} />
        )}
        {modifiedTime && (
            <meta name="last-modified" content={modifiedTime} />
        )}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={fullOgImage} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

        {gaId && (
            <>
                <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} async></script>
                <script is:inline define:vars={{ gaId }}>
                    window.dataLayer = window.dataLayer || [];
                    function gtag() { dataLayer.push(arguments); }
                    window.gtag = gtag;
                    // Consent Mode v2 — default DENY, upgrade on user accept via CookieBanner
                    gtag('consent', 'default', {
                        ad_storage: 'denied',
                        ad_user_data: 'denied',
                        ad_personalization: 'denied',
                        analytics_storage: 'denied',
                        functionality_storage: 'granted',
                        security_storage: 'granted',
                        wait_for_update: 500,
                    });
                    // Restore consent from localStorage if already given
                    try {
                        const saved = JSON.parse(localStorage.getItem('cookie-consent') || 'null');
                        if (saved && saved.analytics) {
                            gtag('consent', 'update', {
                                analytics_storage: 'granted',
                                ad_storage: saved.marketing ? 'granted' : 'denied',
                                ad_user_data: saved.marketing ? 'granted' : 'denied',
                                ad_personalization: saved.marketing ? 'granted' : 'denied',
                            });
                        }
                    } catch (_) {}
                    gtag('js', new Date());
                    gtag('config', gaId, { anonymize_ip: true });
                </script>
            </>
        )}
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap"
            rel="stylesheet"
        />

        <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
        {breadcrumbSchema && (
            <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
        )}
        {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    </head>
    <body class="bg-slate-50 text-slate-900 antialiased selection:bg-blue-100 selection:text-blue-900 min-h-screen flex flex-col font-sans">
        <a href="#main" class="skip-link">Salta al contenuto principale</a>

        <SiteHeader currentPath={currentPath} />

        {breadcrumbs && breadcrumbs.length > 0 && (
            <nav class="flex items-center text-xs text-slate-500 px-4 max-w-7xl mx-auto mt-4" aria-label="Breadcrumb">
                <ol class="flex items-center gap-1 flex-wrap">
                    {breadcrumbs.map((b, i) => (
                        <li class="flex items-center gap-1">
                            {i < breadcrumbs.length - 1 ? (
                                <>
                                    <a href={b.href} class="hover:text-blue-600">{b.label}</a>
                                    <span aria-hidden="true">›</span>
                                </>
                            ) : (
                                <span class="font-medium text-slate-800" aria-current="page">{b.label}</span>
                            )}
                        </li>
                    ))}
                </ol>
            </nav>
        )}

        <main id="main" class="flex-1" tabindex="-1">
            <slot />
        </main>

        <p class="text-xs text-slate-400 text-center py-4" aria-label="Ultimo aggiornamento dei contenuti">
            Ultimo aggiornamento: {LAST_UPDATED}
        </p>

        <Footer client:idle />
        <StickyContactBar client:idle />
        <AccessibilityToolbar client:idle />
        <CookieBanner client:idle />
        <ExitIntentModal client:idle />
    </body>
</html>
