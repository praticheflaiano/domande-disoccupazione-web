---
import '../index.css';
import { SITE_URL } from '../lib/routes';
import SiteHeader from '../components/SiteHeader.astro';
import Footer from '../components/Footer';
import StickyContactBar from '../components/StickyContactBar';
import AccessibilityToolbar from '../components/AccessibilityToolbar';
import CookieBanner from '../components/CookieBanner';
import { LAST_UPDATED } from '../constants';

export interface Props {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    ogType?: 'website' | 'article';
    publishedTime?: string;
    modifiedTime?: string;
    articleSection?: string;
    articleAuthor?: string;
    breadcrumbs?: Array<{ label: string; href: string }>;
    jsonLd?: unknown;
}

const {
    title,
    description,
    canonical,
    ogImage = '/og/cover.png',
    ogType = 'website',
    publishedTime,
    modifiedTime,
    articleSection,
    articleAuthor,
    breadcrumbs,
    jsonLd,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = canonical ?? new URL(currentPath, SITE_URL).toString();
const fullOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).toString();

const organizationSchema = {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': `${SITE_URL}/#organization`,
    name: 'Centro Pratiche Flaiano',
    url: SITE_URL,
    telephone: '+390697845429',
    email: 'info@praticheflaiano.it',
    address: {
        '@type': 'PostalAddress',
        streetAddress: 'Via Filoteo Alberini, 25/int 10',
        addressLocality: 'Roma',
        postalCode: '00139',
        addressRegion: 'RM',
        addressCountry: 'IT',
    },
    openingHoursSpecification: [
        {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'],
            opens: '09:30',
            closes: '18:00',
        },
        {
            '@type': 'OpeningHoursSpecification',
            dayOfWeek: 'Friday',
            opens: '09:30',
            closes: '14:00',
        },
    ],
    areaServed: 'IT',
    priceRange: '€€',
    description:
        "Centro Pratiche Flaiano (Roma) assiste nella domanda NASpI e disoccupazione INPS, con calcolatore online, guide aggiornate e invio domanda telematica.",
};

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0
    ? {
          '@context': 'https://schema.org',
          '@type': 'BreadcrumbList',
          itemListElement: breadcrumbs.map((b, i) => ({
              '@type': 'ListItem',
              position: i + 1,
              name: b.label,
              item: new URL(b.href, SITE_URL).toString(),
          })),
      }
    : null;

const GA4_REGEX = /^G-[A-Z0-9]{8,}$/i;
const GTM_REGEX = /^GTM-[A-Z0-9]{6,}$/i;

const rawGa4 = (import.meta.env.PUBLIC_GA4_ID ?? '').toString().trim();
const rawGtm = (import.meta.env.PUBLIC_GTM_ID ?? '').toString().trim();

let ga4Id: string | null = null;
if (rawGa4) {
    if (GA4_REGEX.test(rawGa4)) {
        ga4Id = rawGa4;
    } else {
        console.warn(`[Base.astro] PUBLIC_GA4_ID non valido ("${rawGa4}"): atteso formato G-XXXXXXXXXX. Snippet GA4 non iniettato.`);
    }
}

let gtmId: string | null = null;
if (rawGtm) {
    if (GTM_REGEX.test(rawGtm)) {
        gtmId = rawGtm;
    } else {
        console.warn(`[Base.astro] PUBLIC_GTM_ID non valido ("${rawGtm}"): atteso formato GTM-XXXXXXX. Snippet GTM non iniettato.`);
    }
}
---

<!DOCTYPE html>
<html lang="it">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />
        <link rel="alternate" hreflang="it-IT" href={canonicalUrl} />

        <meta property="og:type" content={ogType} />
        <meta property="og:locale" content="it_IT" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={fullOgImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="Centro Pratiche Flaiano" />
        {ogType === 'article' && publishedTime && (
            <meta property="article:published_time" content={publishedTime} />
        )}
        {ogType === 'article' && modifiedTime && (
            <meta property="article:modified_time" content={modifiedTime} />
        )}
        {ogType === 'article' && articleSection && (
            <meta property="article:section" content={articleSection} />
        )}
        {ogType === 'article' && articleAuthor && (
            <meta property="article:author" content={articleAuthor} />
        )}
        {modifiedTime && (
            <meta name="last-modified" content={modifiedTime} />
        )}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={fullOgImage} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;1,600&display=swap"
            rel="stylesheet"
        />

        {/* Analytics: opt-in via PUBLIC_GA4_ID o PUBLIC_GTM_ID — vedi docs/seo-submission.md */}
        {gtmId && (
            <script is:inline define:vars={{ gtmId }}>
                (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',gtmId);
            </script>
        )}
        {ga4Id && (
            <>
                <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
                <script is:inline define:vars={{ ga4Id }}>
                    window.dataLayer = window.dataLayer || [];
                    function gtag(){dataLayer.push(arguments);}
                    gtag('js', new Date());
                    gtag('config', ga4Id);
                </script>
            </>
        )}

        <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
        {breadcrumbSchema && (
            <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
        )}
        {jsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
    </head>
    <body class="bg-slate-50 text-slate-900 antialiased selection:bg-blue-100 selection:text-blue-900 min-h-screen flex flex-col font-sans">
        {gtmId && (
            <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`} height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        )}
        <a href="#main" class="skip-link">Salta al contenuto principale</a>

        <SiteHeader currentPath={currentPath} />

        {breadcrumbs && breadcrumbs.length > 0 && (
            <nav class="flex items-center text-xs text-slate-500 px-4 max-w-7xl mx-auto mt-4" aria-label="Breadcrumb">
                <ol class="flex items-center gap-1 flex-wrap">
                    {breadcrumbs.map((b, i) => (
                        <li class="flex items-center gap-1">
                            {i < breadcrumbs.length - 1 ? (
                                <>
                                    <a href={b.href} class="hover:text-blue-600">{b.label}</a>
                                    <span aria-hidden="true">›</span>
                                </>
                            ) : (
                                <span class="font-medium text-slate-800" aria-current="page">{b.label}</span>
                            )}
                        </li>
                    ))}
                </ol>
            </nav>
        )}

        <main id="main" class="flex-1" tabindex="-1">
            <slot />
        </main>

        <p class="text-xs text-slate-400 text-center py-4" aria-label="Ultimo aggiornamento dei contenuti">
            Ultimo aggiornamento: {LAST_UPDATED}
        </p>

        <Footer client:idle />
        <StickyContactBar client:idle />
        <AccessibilityToolbar client:idle />
        <CookieBanner client:idle />
    </body>
</html>
