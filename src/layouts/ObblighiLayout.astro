---
import Base from './Base.astro';
import ObblighiNav from '../components/ObblighiNav.astro';
import RelatedPages from '../components/RelatedPages.astro';
import ConversionCTA from '../components/ConversionCTA';
import { LAST_UPDATED } from '../constants';
import { SITE_URL } from '../lib/routes';

export interface Props {
    title: string;
    description: string;
    slug: string;
    h1: string;
    kicker: string;
    sources: string[];
    faq?: Array<{ q: string; a: string }>;
}

const { title, description, slug, h1, kicker, sources, faq } = Astro.props;

const breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: 'Obblighi NASpI', href: '/obblighi' },
    { label: h1, href: `/obblighi/${slug}` },
];

const faqSchema = faq && faq.length > 0 ? {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
} : undefined;

const articleSchema = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: h1,
    description,
    datePublished: LAST_UPDATED,
    dateModified: LAST_UPDATED,
    inLanguage: 'it-IT',
    mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(`/obblighi/${slug}`, SITE_URL).toString() },
    author: { '@id': `${SITE_URL}/#organization` },
    publisher: { '@id': `${SITE_URL}/#organization` },
    image: `${SITE_URL}/og/cover.png`,
};

const combinedSchema = faqSchema ? [articleSchema, faqSchema] : articleSchema;
---

<Base
    title={title}
    description={description}
    breadcrumbs={breadcrumbs}
    jsonLd={combinedSchema}
    modifiedTime={LAST_UPDATED}
>
    <article class="max-w-4xl mx-auto py-12 px-4 space-y-10">
        <header>
            <p class="text-sm font-semibold text-blue-600 uppercase tracking-wider mb-2">{kicker}</p>
            <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-4">{h1}</h1>
            <p class="text-sm text-slate-500">Aggiornato al <time datetime={LAST_UPDATED}>{LAST_UPDATED}</time></p>
        </header>

        <div class="prose prose-slate max-w-none prose-headings:text-slate-900 prose-a:text-blue-600">
            <slot />
        </div>

        {faq && faq.length > 0 && (
            <section aria-labelledby="faq-heading">
                <h2 id="faq-heading" class="text-2xl font-bold text-slate-900 mb-6">Domande frequenti</h2>
                <dl class="space-y-4">
                    {faq.map((item) => (
                        <div class="bg-slate-50 border border-slate-200 rounded-xl p-5">
                            <dt class="font-bold text-slate-900 mb-2">{item.q}</dt>
                            <dd class="text-slate-700 leading-relaxed">{item.a}</dd>
                        </div>
                    ))}
                </dl>
            </section>
        )}

        <ConversionCTA
            variant="inline"
            headline="Ti aiutiamo a gestire tutti gli obblighi"
            subline="Compiliamo per te la NASpI-Com quando cambi lavoro, controlliamo le scadenze SIISL e CPI, segnaliamo le decurtazioni sbagliate. Un solo numero WhatsApp per tutto il periodo di NASpI."
        />

        <section class="bg-slate-50 border border-slate-200 rounded-2xl p-5 text-sm text-slate-600">
            <h2 class="font-bold text-slate-900 text-base mb-2">Fonti normative</h2>
            <ul class="space-y-1">
                {sources.map((source) => <li>• {source}</li>)}
            </ul>
        </section>

        <section>
            <h2 class="text-2xl font-bold text-slate-900 mb-4">Continua la guida</h2>
            <ObblighiNav current={slug} />
        </section>

        <section class="bg-white border border-slate-200 rounded-2xl p-5 text-sm text-slate-600">
            <h2 class="font-bold text-slate-900 text-base mb-2">A cura della redazione</h2>
            <p class="leading-relaxed">
                Contenuto redatto e aggiornato dalla redazione del
                <a href="/chi-siamo" class="text-blue-600 hover:underline font-semibold">Centro Pratiche Flaiano</a>
                — CAF e patronato di Roma specializzato in pratiche NASpI e ammortizzatori sociali.
                Ultima revisione normativa: <time datetime={LAST_UPDATED}>{LAST_UPDATED}</time>.
            </p>
        </section>
    </article>

    <RelatedPages current={`obblighi/${slug}`} />
</Base>
