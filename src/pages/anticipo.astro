---
import Base from '../layouts/Base.astro';
import AnticipoNaspi from '../components/AnticipoNaspi';
import RelatedPages from '../components/RelatedPages.astro';

const breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: 'Anticipo NASpI', href: '/anticipo' },
];
---

<Base
    title="Anticipo NASpI 2026: liquidazione in unica soluzione"
    description="Richiedi la liquidazione anticipata della NASpI per avvio di attività autonoma, P.IVA o cooperativa. Calcolo capitale, tassazione separata e istruzioni."
    breadcrumbs={breadcrumbs}
>
    <AnticipoNaspi client:load />

    <RelatedPages current="anticipo" />
</Base>
