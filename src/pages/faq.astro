---
import Base from '../layouts/Base.astro';
import KnowledgeBase from '../components/KnowledgeBase';
import RelatedPages from '../components/RelatedPages.astro';
import { FAQS, stripHtml } from '../data/faqs';

const breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: 'FAQ NASpI', href: '/faq' },
];

const faqJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: FAQS.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: {
            '@type': 'Answer',
            text: stripHtml(f.answer),
        },
    })),
};
---

<Base
    title="FAQ NASpI 2026: domande e risposte sui requisiti"
    description="Risposte alle domande più frequenti sulla NASpI 2026: requisiti, dimissioni per giusta causa, SIISL, novità normative e casi particolari."
    breadcrumbs={breadcrumbs}
    jsonLd={faqJsonLd}
>
    <KnowledgeBase client:load />

    <RelatedPages current="faq" />
</Base>
