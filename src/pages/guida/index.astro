---
import Base from '../../layouts/Base.astro';
import GuidaNav from '../../components/GuidaNav.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import ConversionCTA from '../../components/ConversionCTA';
import { LAST_UPDATED } from '../../constants';

const breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: 'Guida operativa', href: '/guida' },
];

const howToSchema = {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'Guida operativa completa alla NASpI 2026',
    description: 'Tutte le procedure, i moduli e i casi particolari per ottenere e gestire correttamente l\'indennità di disoccupazione NASpI nel 2026.',
    step: [
        { '@type': 'HowToStep', position: 1, name: 'Presenta la domanda', text: 'Accedi al portale INPS con SPID/CIE, compila il modello NASpI entro 68 giorni dalla cessazione.' },
        { '@type': 'HowToStep', position: 2, name: 'Presenta la DID', text: 'Dichiarazione di Immediata Disponibilità al lavoro: da trasmettere contestualmente o entro la firma PAD su SIISL.' },
        { '@type': 'HowToStep', position: 3, name: 'Gestisci la fiscalità', text: 'Verifica la Certificazione Unica, compila il 730 o il modello Redditi considerando l\'IRPEF trattenuta dall\'INPS.' },
        { '@type': 'HowToStep', position: 4, name: 'Richiedi ANF e altre prestazioni', text: 'L\'Assegno al Nucleo Familiare è cumulabile con la NASpI: se hai figli a carico, verifica le tabelle 2026.' },
        { '@type': 'HowToStep', position: 5, name: 'Gestisci eventi particolari', text: 'Maternità, malattia, trasferimento all\'estero: ogni evento ha regole specifiche — vedi le pagine dedicate.' },
    ],
};
---

<Base
    title="Guida operativa NASpI 2026: tutto quello che devi sapere"
    description="Guida completa e aggiornata alla NASpI 2026: come presentare la domanda, DID online, fiscalità e 730, ANF, maternità, trasferimento estero, ricorsi. Procedure, moduli e fonti ufficiali."
    breadcrumbs={breadcrumbs}
    jsonLd={howToSchema}
>
    <article class="max-w-5xl mx-auto py-12 px-4 space-y-12">
        <header>
            <p class="text-sm font-semibold text-teal-700 uppercase tracking-wider mb-2">Guida operativa 2026</p>
            <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-4">Tutto sulla NASpI, in 7 guide pratiche</h1>
            <p class="text-lg text-slate-600 leading-relaxed max-w-3xl">
                Sette guide operative per gestire correttamente ogni fase della NASpI: dalla presentazione della domanda alla
                fiscalità, dalla maternità al trasferimento all'estero. Ciascuna pagina contiene procedura esatta, moduli,
                riferimenti normativi e sanzioni. Aggiornate al {LAST_UPDATED}.
            </p>
        </header>

        <section class="bg-slate-900 text-white rounded-3xl p-6 md:p-10">
            <h2 class="text-2xl md:text-3xl font-bold mb-6">Percorso consigliato</h2>
            <ol class="grid md:grid-cols-2 gap-4 text-slate-200">
                <li class="flex gap-3">
                    <span class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-500 text-white font-bold flex items-center justify-center">1</span>
                    <div>
                        <a href="/guida/presentare-domanda" class="font-bold text-white hover:text-teal-300 underline-offset-4 hover:underline">Presenta la domanda NASpI</a>
                        <p class="text-sm text-slate-300 mt-1">Portale INPS, SPID, mandato, scadenza 68 giorni.</p>
                    </div>
                </li>
                <li class="flex gap-3">
                    <span class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-500 text-white font-bold flex items-center justify-center">2</span>
                    <div>
                        <a href="/guida/did" class="font-bold text-white hover:text-teal-300 underline-offset-4 hover:underline">DID Online</a>
                        <p class="text-sm text-slate-300 mt-1">Dichiarazione immediata disponibilità al lavoro.</p>
                    </div>
                </li>
                <li class="flex gap-3">
                    <span class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-500 text-white font-bold flex items-center justify-center">3</span>
                    <div>
                        <a href="/obblighi/siisl" class="font-bold text-white hover:text-teal-300 underline-offset-4 hover:underline">Firma il PAD su SIISL</a>
                        <p class="text-sm text-slate-300 mt-1">Entro 15 giorni dall'accoglimento della domanda.</p>
                    </div>
                </li>
                <li class="flex gap-3">
                    <span class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-500 text-white font-bold flex items-center justify-center">4</span>
                    <div>
                        <a href="/guida/anf" class="font-bold text-white hover:text-teal-300 underline-offset-4 hover:underline">Richiedi l'ANF</a>
                        <p class="text-sm text-slate-300 mt-1">Assegno Nucleo Familiare: cumulabile con la NASpI.</p>
                    </div>
                </li>
                <li class="flex gap-3">
                    <span class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-500 text-white font-bold flex items-center justify-center">5</span>
                    <div>
                        <a href="/guida/fiscalita" class="font-bold text-white hover:text-teal-300 underline-offset-4 hover:underline">Gestisci la fiscalità</a>
                        <p class="text-sm text-slate-300 mt-1">CU, 730, Redditi, conguaglio IRPEF.</p>
                    </div>
                </li>
                <li class="flex gap-3">
                    <span class="flex-shrink-0 w-8 h-8 rounded-full bg-teal-500 text-white font-bold flex items-center justify-center">6</span>
                    <div>
                        <a href="/guida/maternita-malattia" class="font-bold text-white hover:text-teal-300 underline-offset-4 hover:underline">Maternità e malattia</a>
                        <p class="text-sm text-slate-300 mt-1">Cosa succede se ti ammali o entri in congedo.</p>
                    </div>
                </li>
            </ol>
        </section>

        <section>
            <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Tutte le guide</h2>
            <p class="text-slate-600 mb-6 max-w-3xl">Sette approfondimenti monografici con procedura, tempi, riferimenti normativi e moduli scaricabili.</p>
            <GuidaNav />
        </section>

        <section class="bg-blue-50 border border-blue-100 rounded-3xl p-6 md:p-8">
            <h2 class="text-2xl font-bold text-blue-900 mb-3">Cerchi le FAQ?</h2>
            <p class="text-blue-800 mb-4">Le <strong>domande e risposte</strong> più frequenti (requisiti, dimissioni, giusta causa, novità normative) sono nella pagina dedicata.</p>
            <a href="/faq" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold px-6 py-3 rounded-lg">Vai alle FAQ →</a>
        </section>

        <ConversionCTA
            variant="inline"
            headline="Non vuoi leggere tutto? Facciamo noi al posto tuo"
            subline="Il Centro Pratiche Flaiano si occupa di tutta la pratica: domanda, DID, SIISL, comunicazioni periodiche. Tu devi solo inviare i documenti su WhatsApp."
        />
    </article>

    <RelatedPages current="guida" />
</Base>
