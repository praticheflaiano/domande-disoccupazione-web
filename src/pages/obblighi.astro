---
import Base from '../layouts/Base.astro';
import Obligations from '../components/Obligations';

const breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: 'Obblighi e SIISL', href: '/obblighi' },
];
---

<Base
    title="Obblighi NASpI 2026: SIISL, PAD e programma GOL"
    description="Guida completa agli obblighi del percettore NASpI: iscrizione SIISL, Patto di Attivazione Digitale, programma GOL e sanzioni per inadempienza."
    breadcrumbs={breadcrumbs}
>
    <div class="max-w-4xl mx-auto py-8 px-4">
        <Obligations client:visible />
    </div>
</Base>
