        <table class="w-full text-sm border-collapse">
            <thead class="bg-slate-900 text-white">
                <tr>
                    <th class="p-3 text-left">Inadempimento</th>
                    <th class="p-3 text-left">1ª volta</th>
                    <th class="p-3 text-left">2ª volta</th>
                    <th class="p-3 text-left">3ª volta</th>
                </tr>
            </thead>
            <tbody class="divide-y">
                <tr class="bg-white">
                    <td class="p-3 font-semibold">Mancata firma PAD / CV SIISL incompleto</td>
                    <td class="p-3">Decurt. 25% di 1 mensilità (circa 7 giorni)</td>
                    <td class="p-3">Decurt. 1 mensilità</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza</td>
                </tr>
                <tr class="bg-slate-50">
                    <td class="p-3 font-semibold">Mancata presentazione a convocazione CPI</td>
                    <td class="p-3">Decurt. 25% di 1 mensilità</td>
                    <td class="p-3">Decurt. 1 mensilità</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza + perdita stato disoccupazione</td>
                </tr>
                <tr class="bg-white">
                    <td class="p-3 font-semibold">Mancata partecipazione a colloquio di orientamento / PSP</td>
                    <td class="p-3">Decurt. 25%</td>
                    <td class="p-3">1 mensilità</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza</td>
                </tr>
                <tr class="bg-slate-50">
                    <td class="p-3 font-semibold">Mancata partecipazione a corso GOL prenotato</td>
                    <td class="p-3">Decurt. 1 mensilità</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza</td>
                    <td class="p-3">—</td>
                </tr>
                <tr class="bg-amber-50">
                    <td class="p-3 font-semibold">Rifiuto di un'offerta di lavoro congrua</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza immediata</td>
                    <td class="p-3">—</td>
                    <td class="p-3">—</td>
                </tr>
                <tr class="bg-amber-50">
                    <td class="p-3 font-semibold">Omessa NASpI-Com per nuovo rapporto</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza retroattiva + restituzione somme</td>
                    <td class="p-3">—</td>
                    <td class="p-3">—</td>
                </tr>
                <tr class="bg-amber-50">
                    <td class="p-3 font-semibold">Superamento soglie reddito compatibile</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza dal mese di superamento</td>
                    <td class="p-3">—</td>
                    <td class="p-3">—</td>
                </tr>
                <tr class="bg-amber-50">
                    <td class="p-3 font-semibold">Dichiarazione mendace nella domanda iniziale</td>
                    <td class="p-3 text-red-700 font-bold">Decadenza + denuncia penale</td>
                    <td class="p-3">—</td>
