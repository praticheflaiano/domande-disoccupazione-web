---
import Base from '../layouts/Base.astro';
import ApplyOnline from '../components/ApplyOnline';
import RelatedPages from '../components/RelatedPages.astro';

const breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: 'Invia domanda online', href: '/richiedi' },
];
---

<Base
    title="Domanda NASpI: Affidati a Professionisti | Invia Online 24h"
    description="Non rischiare errori con la tua domanda NASpI. Carica i documenti, noi verifichiamo tutto e inviamo la pratica all'INPS in 24 ore. Massima sicurezza e velocità."
    breadcrumbs={breadcrumbs}
>
    <ApplyOnline client:load />

    <RelatedPages current="richiedi" />
</Base>
