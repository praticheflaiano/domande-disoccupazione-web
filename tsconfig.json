{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": [
        ".astro/types.d.ts",
        "src",
        "api"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "domandedisoccupazione.it---centro-pratiche-flaiano"
    ]
}
